{
    "name": "infocyph/uid",
    "description": "UUID (RFC 9562), ULID, Snowflake ID, Sonyflake ID, and TBSL generator for PHP.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "uuid",
        "ulid",
        "snowflake",
        "sonyflake",
        "tbsl",
        "ksuid",
        "xid",
        "id",
        "key",
        "unique",
        "rfc4122",
        "rfc9562"
    ],
    "authors": [
        {
            "name": "abmmhasan",
            "email": "abmmhasan@gmail.com"
        }
    ],
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "Infocyph\\UID\\": "src/"
        }
    },
    "replace": {
        "abmmhasan/uuid": "*"
    },
    "require": {
        "php": ">=8.2",
        "ext-bcmath": "*",
        "psr/simple-cache": "^3.0"
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "classmap-authoritative": true
    }
}
